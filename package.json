{
    "name": "markdown-spec-edit",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "src/electron/main.js",
    "scripts": {
        "dev": "vite",
        "electron": "electron .",
        "build": "tsc -b && vite build",
